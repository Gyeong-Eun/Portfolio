file_path = '파일_경로.csv'
data = pd.read_csv(file_path)

# 평가 프롬프트 생성 함수
def create_prompt(row):
    return f"""
    당신은 뉴스 헤드라인 평가자입니다. 
    당신에게는 AI가 생성한 기사 헤드라인이 주어집니다. 
    주어진 신문 기사를 읽고 적절한 제목이 생성되었는지를 평가하는 것이 과제입니다. 
    아래의 평가 단계를 따라주시길 바랍니다.
    또한 아래의 평가 기준을 사용해야 하며, 이 지침을 주의 깊게 읽고 이해하시길 바랍니다. 
    
    평가기준:
    0점: 헤드라인으로 전혀 적합하지 않으며, 이해할 수 없는 문장 구조를 가짐.
    1점: 헤드라인으로 적합하지 않지만, 문장은 이해 가능함.
    2점: 헤드라인으로 어느 정도 적합하지만, 구체성이 부족함.
    3점: 헤드라인으로 적합하며, 뉴스 헤드라인으로으로서 기본적인 요건을 충족함.
    4점: 헤드라인으로 적합하며, 약간의 개선이 필요함.
    5점: 헤드라인으로 매우 적합하며, 독자의 관심을 끌 수 있는 헤드라인으로 이상적임.

    다음은 예시로 평가할 수 있는 헤드라인입니다:
    - '기후 변화가 경제에 미치는 영향, 예측보다 심각해'
    - 'AI가 우리의 일상을 바꾼 5가지 방법'
    - '차세대 스마트폰의 혁신: 기대할 만한 기능들'

    평가할 데이터는 다음과 같습니다:

    제목:
    {row['제목']}

    점수(0~5):
    """

# 각 행에 대해 프롬프트 생성
data['evaluation_prompt'] = data.apply(create_prompt, axis=1)

